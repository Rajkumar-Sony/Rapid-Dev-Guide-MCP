{
  "name": "rapid-dev-guide-mcp",
  "version": "0.1.1",
  "description": "MCP server for applying Rapid Dev Guide development rules to software projects.",
  "type": "module",
  "license": "UNLICENSED",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "development-rules",
    "ai-coding",
    "rapid-dev-guide"
  ],
  "bin": {
    "rapid-dev-guide-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "rules/*.md",
    "*.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
